# PostgreSQL Configuration
POSTGRES_DB=lab_db
POSTGRES_USER=lab_user
POSTGRES_PASSWORD=lab_password

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# DB Connection (used by Flask)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lab_db
DB_USER=lab_user
DB_PASSWORD=lab_password
